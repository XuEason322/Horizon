{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "MiniMax-M3",
    "api_key_env": "OPENAI_API_KEY",
    "base_url_env": "OPENAI_BASE_URL",
    "temperature": 0.3,
    "max_tokens": 4096
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 20,
      "min_score": 100
    },
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "worldnews",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 50
        }
      ],
      "fetch_comments": 5
    },
    "rss": [
      {
        "name": "BBC News",
        "url": "http://feeds.bbci.co.uk/news/rss.xml",
        "enabled": true,
        "category": "world"
      }
    ]
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24,
    "max_items": null
  },
  "email": {
    "enabled": false
  },
  "webhook": {
    "enabled": false
  }
}
