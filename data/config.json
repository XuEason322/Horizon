{
  "ai": {
    "provider": "openai",
    "model": "MiniMax-M3",
    "api_key_env": "OPENAI_API_KEY",
    "base_url_env": "OPENAI_BASE_URL"
  },
  "sources": {
    "hacker_news": {
      "enabled": true,
      "url": "https://news.ycombinator.com"
    },
    "reddit_worldnews": {
      "enabled": true,
      "url": "https://www.reddit.com/r/worldnews"
    },
    "bbc_news": {
      "enabled": true,
      "url": "https://www.bbc.com/news"
    }
  },
  "summary": {
    "language": "zh",
    "max_length": 500
  }
}
