{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "MiniMax-M3",
    "api_key_env": "OPENAI_API_KEY",
    "base_url_env": "OPENAI_BASE_URL",
    "temperature": 0.3,
    "max_tokens": 4096
  },
  "sources": {
    "rss": [
      {
        "name": "BBC News",
        "url": "http://feeds.bbci.co.uk/news/rss.xml",
        "enabled": true,
        "category": "world"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "worldnews",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10
        }
      ]
    }
  },
  "filtering": {
    "ai_score_threshold": 5.0,
    "time_window_hours": 24,
    "max_items": 15
  },
  "summary": {
    "language": "zh",
    "max_length": 600
  },
  "email": {
    "enabled": false
  },
  "webhook": {
    "enabled": false
  }
}
